<Window x:Class="Pawshot_Windows.PreviewWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Preview" Height="180" Width="280"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False">
    
    <Border x:Name="MainBorder" Margin="15" CornerRadius="12" Background="White" BorderBrush="#EEE" BorderThickness="1" MouseEnter="MainBorder_MouseEnter" MouseLeave="MainBorder_MouseLeave">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.3" Color="Black"/>
        </Border.Effect>
        <Grid>
            <!-- サムネイル画像（アノテーションモード） -->
            <Image x:Name="PreviewImage" Margin="8" Stretch="Uniform" />
            
            <!-- OCRテキスト表示（OCRモード） -->
            <Border x:Name="OcrPanel" Visibility="Collapsed" Padding="10,8">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="OcrText" TextWrapping="Wrap" FontSize="12" Foreground="#222"
                               FontFamily="Segoe UI" VerticalAlignment="Center"/>
                </ScrollViewer>
            </Border>

            <!-- OCRモード用ヘッダー -->
            <Border x:Name="OcrHeader" Visibility="Collapsed" VerticalAlignment="Top" Height="26"
                    Background="#2196F3" CornerRadius="12,12,0,0">
                <TextBlock Text="🔤 OCR — テキストをコピー済み" Foreground="White" FontSize="11"
                           HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold"/>
            </Border>

            <!-- マウスホバー時に出すクイックアクション -->
            <Border x:Name="ActionsOverlay" Background="#AA000000" CornerRadius="0,0,12,12" VerticalAlignment="Bottom" Height="40" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <Button Content="フォルダを開く" Click="OpenFolder_Click" Foreground="White" Background="Transparent" BorderThickness="0" Margin="5,0" Cursor="Hand" />
                    <Separator Width="1" Background="#55FFFFFF" Margin="5,8" />
                    <Button Content="コピー" Click="Copy_Click" Foreground="White" Background="Transparent" BorderThickness="0" Margin="5,0" Cursor="Hand" />
                </StackPanel>
            </Border>
            
            <!-- 閉じるボタン -->
            <Button Content="×" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="5" Padding="5,0" Background="Transparent" BorderThickness="0" Foreground="#AAA" FontSize="14" Click="Close_Click" />
        </Grid>
    </Border>
</Window>
